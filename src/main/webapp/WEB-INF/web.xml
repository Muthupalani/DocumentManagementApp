<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         version="5.0">
<welcome-file-list>
    <welcome-file>home.jsp</welcome-file>
</welcome-file-list>


<filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.documentapp.filter.AuthFilter</filter-class>
</filter>

<filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/*</url-pattern>
</filter-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.documentapp.controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.documentapp.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

   
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.documentapp.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

   
    <servlet>
        <servlet-name>FileListServlet</servlet-name>
        <servlet-class>com.documentapp.controller.FileListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FileListServlet</servlet-name>
        <url-pattern>/files</url-pattern>
    </servlet-mapping>

    
    <servlet>
        <servlet-name>FileVersionServlet</servlet-name>
        <servlet-class>com.documentapp.controller.FileVersionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FileVersionServlet</servlet-name>
        <url-pattern>/versions</url-pattern>
    </servlet-mapping>


    <servlet>
        <servlet-name>UploadFileServlet</servlet-name>
        <servlet-class>com.documentapp.controller.UploadFileServlet</servlet-class>
        <multipart-config>
            <max-file-size>10485760</max-file-size>
            <max-request-size>20971520</max-request-size>
            <file-size-threshold>0</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>UploadFileServlet</servlet-name>
        <url-pattern>/upload</url-pattern>
    </servlet-mapping>


    <servlet>
        <servlet-name>FileDownloadServlet</servlet-name>
        <servlet-class>com.documentapp.controller.FileDownloadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FileDownloadServlet</servlet-name>
        <url-pattern>/download</url-pattern>
    </servlet-mapping>
    
    
<servlet>
    <servlet-name>ViewFileServlet</servlet-name>
    <servlet-class>com.documentapp.controller.ViewFileServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ViewFileServlet</servlet-name>
    <url-pattern>/view</url-pattern>
</servlet-mapping>


<servlet>
    <servlet-name>VersionDetailsServlet</servlet-name>
    <servlet-class>com.documentapp.controller.VersionDetailsServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>VersionDetailsServlet</servlet-name>
    <url-pattern>/versionDetails</url-pattern>
</servlet-mapping>


</web-app>